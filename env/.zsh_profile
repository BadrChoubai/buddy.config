# ── Directories ────────────────────────────────────────────────
export XDG_CONFIG_HOME=$HOME/.config
export GOPATH=$HOME/go
export GOBIN=$HOME/go/bin

# ── Editor ─────────────────────────────────────────────────────
export VIM="nvim"
export GIT_EDITOR=$VIM

# ── PATH helpers ───────────────────────────────────────────────
appendPath() {
    if [[ "$PATH" != *"$1"* ]]; then
        export PATH=$PATH:$1
    fi
}

prependPath() {
    if [[ "$PATH" != *"$1"* ]]; then
        export PATH=$1:$PATH
    fi
}

appendPath /usr/local/go/bin
appendPath $GOBIN

# ── nvm ────────────────────────────────────────────────────────
export NVM_DIR="$HOME/.config/nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"

# ── Aliases ────────────────────────────────────────────────────
alias vim="$VIM"
alias k="kubectl"
alias k8s="microk8s"
alias lt="_lt"

# ── Functions ──────────────────────────────────────────────────
dotenv() {
    local file_name="${1:-.env}"
    if [[ -f "$file_name" ]]; then
        set -o allexport
        source "$file_name"
        set +o allexport
    else
        echo "dotenv: file '$file_name' not found." >&2
        return 1
    fi
}

_lt() {
    local treeignore=""
    if [ -f .gitignore ]; then
        local gitignore_pattern
        gitignore_pattern=$(grep -v '^\s*$\|^\s*#' .gitignore | tr '\n' '|' | sed 's/|$//')
        if [ -n "$gitignore_pattern" ]; then
            treeignore="$treeignore|$gitignore_pattern"
        fi
    fi
    treeignore="${treeignore#|}"
    tree -L 1 -I "$treeignore" "$@"
}
